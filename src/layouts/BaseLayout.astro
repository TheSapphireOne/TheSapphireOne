---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Welcome to domi.lu" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/img/icon_domilu.ico" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <style>
      html { scroll-behavior: smooth; }
      body { font-family: 'Noto Sans', ui-sans-serif, system-ui, sans-serif; }
    </style>
  </head>
  <body class="bg-bg-primary dark:bg-secondary text-secondary dark:text-bg-primary transition-colors">
    <script is:inline>
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.classList.add('dark');
      }
    </script>

    <!-- Language toggle -->
    <div class="fixed top-2 right-[88px] z-[100] flex">
      <button
        type="button"
        id="lang-de"
        aria-label="Switch to German"
        class="w-10 h-10 rounded-l-design flex items-center justify-center bg-bg-secondary dark:bg-primary/30 text-secondary dark:text-bg-primary hover:bg-primary/20 dark:hover:bg-primary/50 transition-colors font-semibold text-sm"
      >
        de
      </button>
      <button
        type="button"
        id="lang-en"
        aria-label="Switch to English"
        class="w-10 h-10 rounded-r-design flex items-center justify-center bg-bg-secondary dark:bg-primary/30 text-secondary dark:text-bg-primary hover:bg-primary/20 dark:hover:bg-primary/50 transition-colors font-semibold text-sm"
      >
        en
      </button>
    </div>

    <!-- Dark mode toggle -->
    <button
      id="theme-toggle"
      aria-label="Toggle dark mode"
      class="fixed top-2 right-6 z-[100] w-10 h-10 rounded-design flex items-center justify-center bg-bg-secondary dark:bg-primary/30 text-secondary dark:text-bg-primary hover:bg-primary/20 dark:hover:bg-primary/50 transition-colors shadow-sm"
    >
      <!-- Sun icon (shown in dark mode) -->
      <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="hidden dark:block w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <!-- Moon icon (shown in light mode) -->
      <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="block dark:hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>

    <script is:inline>
      document.getElementById('theme-toggle').addEventListener('click', function () {
        document.documentElement.classList.toggle('dark');
      });

      // Language toggle
      const langDe = document.getElementById('lang-de');
      const langEn = document.getElementById('lang-en');

      // Get current language from URL or localStorage
      function getCurrentLanguage() {
        const urlParams = new URLSearchParams(window.location.search);
        const langParam = urlParams.get('lang');
        if (langParam === 'de' || langParam === 'en') {
          return langParam;
        }
        const storedLang = localStorage.getItem('language');
        return (storedLang === 'de' || storedLang === 'en') ? storedLang : 'en';
      }

      // Set language function
      function setLanguage(lang) {
        localStorage.setItem('language', lang);

        // Update URL without reload using history API
        const url = new URL(window.location.origin + window.location.pathname);
        url.searchParams.set('lang', lang);
        const hash = window.location.hash;
        window.history.pushState({}, '', url.toString() + hash);

        // Hot-swap the language content
        if (window.updateLanguage) {
          window.updateLanguage(lang);
        }

        // Update active button state
        langDe.classList.toggle('active-lang', lang === 'de');
        langEn.classList.toggle('active-lang', lang === 'en');
      }

      // Set initial active language
      const currentLang = getCurrentLanguage();
      if (currentLang === 'de') {
        langDe.classList.add('active-lang');
      } else {
        langEn.classList.add('active-lang');
      }

      // Language button handlers
      langDe.addEventListener('click', function (e) {
        e.preventDefault();
        if (getCurrentLanguage() !== 'de') {
          setLanguage('de');
        }
      });

      langEn.addEventListener('click', function (e) {
        e.preventDefault();
        if (getCurrentLanguage() !== 'en') {
          setLanguage('en');
        }
      });
    </script>

    <style is:global>
      .active-lang {
        background-color: rgb(0 111 186 / 0.2) !important;
        color: #006FBA !important;
      }
      .dark .active-lang {
        background-color: #00A4E4 !important;
        color: #FFFFFF !important;
      }
    </style>

    <slot />
  </body>
</html>
