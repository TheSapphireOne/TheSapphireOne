---
import BaseLayout from '../layouts/BaseLayout.astro';
import { translations } from '../i18n/translations';

// Get current language from URL parameter or localStorage
const urlParams = new URL(Astro.request.url).searchParams;
const lang = (urlParams.get('lang') === 'de' ? 'de' : 'en') as 'en' | 'de';

// Get translations for current language
const t = translations[lang];
---

<BaseLayout title="domi.lu">

  <!-- Banner with background image -->
  <header class="w-full h-[50vh] relative overflow-hidden flex items-end">
    <img src="/img/intro-bg.jpg" alt="Banner background" class="absolute inset-0 w-full h-full object-cover" />
    <!-- Dark gradient overlay at bottom -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
    <div class="relative z-10 px-8 pb-8">
      <h1 class="text-4xl md:text-6xl font-bold text-white" data-i18n="banner.title">{t.banner.title}</h1>
    </div>
  </header>

  <!-- Tab Navigation -->
  <nav id="tab-nav" class="sticky top-0 z-50 bg-bg-primary dark:bg-secondary border-b border-bg-secondary dark:border-primary/30 shadow-sm">
    <div class="max-w-5xl mx-auto px-6 flex">
      <a href="#projects" class="tab-link px-6 py-4 text-base font-semibold border-b-2 transition-colors" data-i18n="nav.projects">
        {t.nav.projects}
      </a>
      <a href="#my-projects" class="tab-link px-6 py-4 text-base font-semibold border-b-2 transition-colors" data-i18n="nav.myProjects">
        {t.nav.myProjects}
      </a>
      <a href="#about" class="tab-link px-6 py-4 text-base font-semibold border-b-2 transition-colors" data-i18n="nav.aboutMe">
        {t.nav.aboutMe}
      </a>
    </div>
  </nav>

  <main class="max-w-5xl mx-auto px-6 py-12">

    <!-- Projects Section -->
    <section id="projects" class="scroll-mt-20 mb-20">
      <h2 class="text-3xl font-bold text-secondary dark:text-bg-primary mb-8" data-i18n="projects.title">{t.projects.title}</h2>
      <div class="grid grid-cols-1 gap-6">

        <!-- Project Card -->
        <div class="bg-bg-secondary dark:bg-primary/10 rounded-design p-6 border border-bg-secondary dark:border-primary/20 hover:shadow-lg transition-shadow">
          <div class="flex flex-col sm:flex-row items-start gap-6">
            <img src="/img/eBanking.png" alt="eBanking App" class="w-[240px] h-auto object-contain shrink-0" />
            <div class="flex flex-col gap-3">
              <h3 class="text-xl font-semibold text-secondary dark:text-bg-primary" data-i18n="projects.eBanking.title">{t.projects.eBanking.title}</h3>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed" data-i18n="projects.eBanking.description1">
                {t.projects.eBanking.description1}
              </p>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed" data-i18n="projects.eBanking.description2">
                {t.projects.eBanking.description2}
              </p>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed" data-i18n="projects.eBanking.description3">
                {t.projects.eBanking.description3}
              </p>

              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed">
                <span data-i18n="projects.eBanking.moreInfo">{t.projects.eBanking.moreInfo}</span> <a href="https://www.zkb.ch/de/private/digitales-banking/mobile-banking/mobile-banking-app.html" target="_blank" rel="noopener noreferrer" class="text-primary dark:text-highlight hover:underline" data-i18n="projects.eBanking.page">{t.projects.eBanking.page}</a>.
              </p>

              <!-- Store badges -->
              <div class="mt-2">
                <div class="flex flex-wrap gap-3 items-center">
                  <a href="https://play.google.com/store/apps/details?id=ch.zkb.slv.mobile.client.android" target="_blank" rel="noopener noreferrer">
                    <img src="/img/google-play-badge.png" alt={t.store.googlePlay} data-i18n-alt="store.googlePlay" class="h-12 w-auto" />
                  </a>
                  <a href="https://apps.apple.com/app/zkb-mobile-banking/id428937855" target="_blank" rel="noopener noreferrer">
                    <img src="/img/apple_store.png" alt={t.store.appStore} data-i18n-alt="store.appStore" class="h-12 w-auto" />
                  </a>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-4 flex gap-2 flex-wrap">
            <a href="https://www.apple.com/ios" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">iOS</a>
            <a href="https://www.android.com" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Android</a>
            <a href="https://kotlinlang.org/docs/multiplatform.html" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Kotlin Multiplatform</a>
            <a href="https://developer.apple.com/swift" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Swift</a>
            <a href="https://kotlinlang.org" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Kotlin</a>
            <a href="https://www.java.com" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Java</a>
          </div>
        </div>

        <!-- Project Card: Frankly -->
        <div class="bg-bg-secondary dark:bg-primary/10 rounded-design p-6 border border-bg-secondary dark:border-primary/20 hover:shadow-lg transition-shadow">
          <div class="flex flex-col sm:flex-row items-start gap-6">
            <img src="/img/frankly.png" alt="Frankly App" class="w-[240px] h-auto object-contain shrink-0" />
            <div class="flex flex-col gap-3">
              <h3 class="text-xl font-semibold text-secondary dark:text-bg-primary" data-i18n="projects.frankly.title">{t.projects.frankly.title}</h3>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed" data-i18n="projects.frankly.description">
                {t.projects.frankly.description}
              </p>

              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed">
                <span data-i18n="projects.frankly.moreInfo">{t.projects.frankly.moreInfo}</span> <a href="https://www.frankly.ch/en/home.html" target="_blank" rel="noopener noreferrer" class="text-primary dark:text-highlight hover:underline" data-i18n="projects.frankly.page">{t.projects.frankly.page}</a>.
              </p>

              <!-- Store badges -->
              <div class="mt-2">
                <div class="flex flex-wrap gap-3 items-center">
                  <a href="https://play.google.com/store/apps/details?id=ch.zkb.frankly" target="_blank" rel="noopener noreferrer">
                    <img src="/img/google-play-badge.png" alt={t.store.googlePlay} data-i18n-alt="store.googlePlay" class="h-12 w-auto" />
                  </a>
                  <a href="https://apps.apple.com/de/app/frankly-s%C3%A4ule-3a-vorsorge/id1498903386" target="_blank" rel="noopener noreferrer">
                    <img src="/img/apple_store.png" alt={t.store.appStore} data-i18n-alt="store.appStore" class="h-12 w-auto" />
                  </a>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-4 flex gap-2 flex-wrap">
            <a href="https://www.apple.com/ios" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">iOS</a>
            <a href="https://www.android.com" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Android</a>
            <a href="https://kotlinlang.org/docs/multiplatform.html" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Kotlin Multiplatform</a>
            <a href="https://kotlinlang.org" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Kotlin</a>
          </div>
        </div>

      </div>
    </section>

    <!-- My Projects Section -->
    <section id="my-projects" class="scroll-mt-20 mb-20">
      <h2 class="text-3xl font-bold text-secondary dark:text-bg-primary mb-8" data-i18n="myProjects.title">{t.myProjects.title}</h2>
      <div class="grid grid-cols-1 gap-6">

        <!-- Project Card: Compendium -->
        <div class="bg-bg-secondary dark:bg-primary/10 rounded-design p-6 border border-bg-secondary dark:border-primary/20 hover:shadow-lg transition-shadow">
          <div class="flex flex-col sm:flex-row items-start gap-6">
            <img src="/img/kompendium.png" alt="Compendium App" class="w-[240px] h-auto object-contain shrink-0" />
            <div class="flex flex-col gap-3">
              <h3 class="text-xl font-semibold text-secondary dark:text-bg-primary" data-i18n="myProjects.compendium.title">{t.myProjects.compendium.title}</h3>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed" data-i18n="myProjects.compendium.description1">
                {t.myProjects.compendium.description1}
              </p>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed" data-i18n="myProjects.compendium.description2">
                {t.myProjects.compendium.description2}
              </p>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed" data-i18n="myProjects.compendium.description3">
                {t.myProjects.compendium.description3}
              </p>

              <!-- Store badges -->
              <div class="mt-2">
                <div class="flex flex-wrap gap-3 items-center">
                  <a href="https://play.google.com/store/apps/details?id=com.treeinspired.android.kompendium" target="_blank" rel="noopener noreferrer">
                    <img src="/img/google-play-badge.png" alt={t.store.googlePlay} data-i18n-alt="store.googlePlay" class="h-12 w-auto" />
                  </a>
                  <a href="https://apps.apple.com/us/app/compendium-medication-guide/id373040910" target="_blank" rel="noopener noreferrer">
                    <img src="/img/apple_store.png" alt={t.store.appStore} data-i18n-alt="store.appStore" class="h-12 w-auto" />
                  </a>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-4 flex gap-2 flex-wrap">
            <a href="https://www.android.com" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Android</a>
            <a href="https://kotlinlang.org" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Kotlin</a>
          </div>
        </div>

        <!-- Project Card: Gambly -->
        <div class="bg-bg-secondary dark:bg-primary/10 rounded-design p-6 border border-bg-secondary dark:border-primary/20 hover:shadow-lg transition-shadow">
          <div class="flex flex-col sm:flex-row items-start gap-6">
            <img src="/img/gambly.png" alt="Gambly App" class="w-[240px] h-auto object-contain shrink-0" />
            <div class="flex flex-col gap-3">
              <h3 class="text-xl font-semibold text-secondary dark:text-bg-primary" data-i18n="myProjects.gambly.title">{t.myProjects.gambly.title}</h3>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed" data-i18n="myProjects.gambly.description1">
                {t.myProjects.gambly.description1}
              </p>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed" data-i18n="myProjects.gambly.description2">
                {t.myProjects.gambly.description2}
              </p>

              <!-- Store badges -->
              <div class="mt-2">
                <div class="flex flex-wrap gap-3 items-center">
                  <a href="https://play.google.com/store/apps/details?id=lu.domi.sapphire.gambly" target="_blank" rel="noopener noreferrer">
                    <img src="/img/google-play-badge.png" alt={t.store.googlePlay} data-i18n-alt="store.googlePlay" class="h-12 w-auto" />
                  </a>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-4 flex gap-2 flex-wrap">
            <a href="https://www.android.com" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Android</a>
            <a href="https://www.java.com" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Java</a>
          </div>
        </div>

      </div>
    </section>

    <!-- About Me Section -->
    <section id="about" class="scroll-mt-20 mb-20">
      <h2 class="text-3xl font-bold text-secondary dark:text-bg-primary mb-8" data-i18n="about.title">{t.about.title}</h2>
      <div class="bg-bg-secondary dark:bg-primary/10 rounded-design p-8 border border-bg-secondary dark:border-primary/20">
        <div class="flex flex-col md:flex-row gap-8 items-start">
          <div class="flex-1">
            <p class="text-secondary/80 dark:text-bg-primary/80 leading-relaxed mb-4" data-i18n="about.paragraph1">
              {t.about.paragraph1}
            </p>
            <p class="text-secondary/80 dark:text-bg-primary/80 leading-relaxed mb-4" data-i18n="about.paragraph2">
              {t.about.paragraph2}
            </p>
            <p class="text-secondary/80 dark:text-bg-primary/80 leading-relaxed mb-4" data-i18n="about.paragraph3">
              {t.about.paragraph3}
            </p>
            <p class="text-secondary/80 dark:text-bg-primary/80 leading-relaxed" data-i18n="about.paragraph4">
              {t.about.paragraph4}
            </p>
          </div>
          <img src="/img/me.png" alt="Profile picture" class="w-[240px] h-auto object-contain rounded-[10px] shrink-0" />
        </div>
      </div>
    </section>

  </main>

  <style is:global>
    .tab-link {
      color: rgb(0 31 78 / 0.5);
      border-color: transparent;
    }
    .tab-link.active {
      color: #001F4E;
      border-color: #001F4E;
    }
    .dark .tab-link {
      color: rgb(255 255 255 / 0.6);
    }
    .dark .tab-link.active {
      color: #FFFFFF;
      border-color: #FFFFFF;
    }
  </style>

  <script>
    const sections = document.querySelectorAll<HTMLElement>('section[id]');
    const tabLinks = document.querySelectorAll<HTMLAnchorElement>('.tab-link');

    function setActive(id: string) {
      tabLinks.forEach((link) => {
        link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
      });
    }

    function getActiveSection(): string {
      const navHeight = (document.getElementById('tab-nav')?.offsetHeight ?? 56);
      let activeId = sections[0]?.id ?? '';
      for (const section of sections) {
        if (section.getBoundingClientRect().top <= navHeight + 8) {
          activeId = section.id;
        }
      }
      return activeId;
    }

    window.addEventListener('scroll', () => setActive(getActiveSection()), { passive: true });
    setActive(getActiveSection());
  </script>

  <script is:inline define:vars={{ translations }}>
    // Make translations globally available for hot-swapping
    window.__translations = translations;

    // Function to update page content with new language
    window.updateLanguage = function(lang) {
      const t = translations[lang];

      // Update all elements with data-i18n attributes
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (!key) return;

        // Navigate nested object using dot notation
        const keys = key.split('.');
        let value = t;
        for (const k of keys) {
          value = value[k];
          if (value === undefined) break;
        }

        if (value !== undefined) {
          el.textContent = value;
        }
      });

      // Update alt text attributes
      document.querySelectorAll('[data-i18n-alt]').forEach(el => {
        const key = el.getAttribute('data-i18n-alt');
        if (!key) return;

        const keys = key.split('.');
        let value = t;
        for (const k of keys) {
          value = value[k];
          if (value === undefined) break;
        }

        if (value !== undefined) {
          el.setAttribute('alt', value);
        }
      });
    };
  </script>

</BaseLayout>
