---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="domi.lu">

  <!-- Banner (~1/3 screen height, placeholder for future image) -->
  <header class="w-full h-[42vh] bg-bg-secondary dark:bg-primary/20 relative overflow-hidden flex items-end">
    <div class="absolute inset-0 bg-gradient-to-br from-bg-secondary via-highlight/10 to-primary/20 dark:from-secondary dark:via-primary/40 dark:to-highlight/10"></div>
    <div class="relative z-10 px-8 pb-8">
      <h1 class="text-4xl md:text-6xl font-bold text-secondary dark:text-bg-primary">Creativity with intelligent solutions</h1>
    </div>
  </header>

  <!-- Tab Navigation -->
  <nav id="tab-nav" class="sticky top-0 z-50 bg-bg-primary dark:bg-secondary border-b border-bg-secondary dark:border-primary/30 shadow-sm">
    <div class="max-w-5xl mx-auto px-6 flex">
      <a href="#projects" class="tab-link px-6 py-4 text-base font-semibold border-b-2 transition-colors">
        Projects
      </a>
      <a href="#my-projects" class="tab-link px-6 py-4 text-base font-semibold border-b-2 transition-colors">
        My Projects
      </a>
      <a href="#about" class="tab-link px-6 py-4 text-base font-semibold border-b-2 transition-colors">
        About Me
      </a>
    </div>
  </nav>

  <main class="max-w-5xl mx-auto px-6 py-12">

    <!-- Projects Section -->
    <section id="projects" class="scroll-mt-20 mb-20">
      <h2 class="text-3xl font-bold text-secondary dark:text-bg-primary mb-8">Projects</h2>
      <div class="grid grid-cols-1 gap-6">

        <!-- Project Card -->
        <div class="bg-bg-secondary dark:bg-primary/10 rounded-design p-6 border border-bg-secondary dark:border-primary/20 hover:shadow-lg transition-shadow">
          <div class="flex flex-col sm:flex-row items-start gap-6">
            <img src="/img/eBanking.png" alt="eBanking App" class="w-[240px] h-auto object-contain shrink-0" />
            <div class="flex flex-col gap-3">
              <h3 class="text-xl font-semibold text-secondary dark:text-bg-primary">eBanking App</h3>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed">
                After maintaining and adding additional features to the old ZKB eBanking app, a decision was made to build a new app from the ground up. We planned and evaluated different tools, strategies, architecture patterns and many key factors until we started our journey with a multiplatform Kotlin/ObjectiveC-Swift solution.
              </p>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed">
                During the development process we constantly improved and refactored our application in the front- as well as in the backend. With a huge amount of tests we guaranteed the quality of our software.
              </p>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed">
                In collaboration with VISA, Samsung, Thales, SIX Group, Apple, Google and others we integrated specialized systems most other competitors could not.
              </p>

              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed">
                More information on the product <a href="https://www.zkb.ch/de/private/digitales-banking/mobile-banking/mobile-banking-app.html" target="_blank" rel="noopener noreferrer" class="text-primary dark:text-highlight hover:underline">page</a>.
              </p>

              <!-- Store badges -->
              <div class="mt-2">
                <div class="flex flex-wrap gap-3 items-center">
                  <a href="https://play.google.com/store/apps/details?id=ch.zkb.slv.mobile.client.android" target="_blank" rel="noopener noreferrer">
                    <img src="/img/google-play-badge.png" alt="Get it on Google Play" class="h-12 w-auto" />
                  </a>
                  <a href="https://apps.apple.com/app/zkb-mobile-banking/id428937855" target="_blank" rel="noopener noreferrer">
                    <img src="/img/apple_store.png" alt="Download on the App Store" class="h-12 w-auto" />
                  </a>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-4 flex gap-2 flex-wrap">
            <a href="https://www.apple.com/ios" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">iOS</a>
            <a href="https://www.android.com" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Android</a>
            <a href="https://kotlinlang.org/docs/multiplatform.html" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Kotlin Multiplatform</a>
            <a href="https://developer.apple.com/swift" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Swift</a>
            <a href="https://kotlinlang.org" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Kotlin</a>
            <a href="https://www.java.com" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Java</a>
          </div>
        </div>

        <!-- Project Card: Frankly -->
        <div class="bg-bg-secondary dark:bg-primary/10 rounded-design p-6 border border-bg-secondary dark:border-primary/20 hover:shadow-lg transition-shadow">
          <div class="flex flex-col sm:flex-row items-start gap-6">
            <img src="/img/frankly.png" alt="Frankly App" class="w-[240px] h-auto object-contain shrink-0" />
            <div class="flex flex-col gap-3">
              <h3 class="text-xl font-semibold text-secondary dark:text-bg-primary">Frankly</h3>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed">
                Frankly is a pillar 3a pension app that makes it easy to manage and control different types of investments yourself. Built with Kotlin Multiplatform, the small and clear app is very easy to use.
              </p>

              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed">
                More information on the product <a href="https://www.frankly.ch/en/home.html" target="_blank" rel="noopener noreferrer" class="text-primary dark:text-highlight hover:underline">page</a>.
              </p>

              <!-- Store badges -->
              <div class="mt-2">
                <div class="flex flex-wrap gap-3 items-center">
                  <a href="https://play.google.com/store/apps/details?id=ch.zkb.frankly" target="_blank" rel="noopener noreferrer">
                    <img src="/img/google-play-badge.png" alt="Get it on Google Play" class="h-12 w-auto" />
                  </a>
                  <a href="https://apps.apple.com/de/app/frankly-s%C3%A4ule-3a-vorsorge/id1498903386" target="_blank" rel="noopener noreferrer">
                    <img src="/img/apple_store.png" alt="Download on the App Store" class="h-12 w-auto" />
                  </a>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-4 flex gap-2 flex-wrap">
            <a href="https://www.apple.com/ios" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">iOS</a>
            <a href="https://www.android.com" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Android</a>
            <a href="https://kotlinlang.org/docs/multiplatform.html" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Kotlin Multiplatform</a>
            <a href="https://kotlinlang.org" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Kotlin</a>
          </div>
        </div>

      </div>
    </section>

    <!-- My Projects Section -->
    <section id="my-projects" class="scroll-mt-20 mb-20">
      <h2 class="text-3xl font-bold text-secondary dark:text-bg-primary mb-8">My Projects</h2>
      <div class="grid grid-cols-1 gap-6">

        <!-- Project Card: Compendium -->
        <div class="bg-bg-secondary dark:bg-primary/10 rounded-design p-6 border border-bg-secondary dark:border-primary/20 hover:shadow-lg transition-shadow">
          <div class="flex flex-col sm:flex-row items-start gap-6">
            <img src="/img/kompendium.png" alt="Compendium App" class="w-[240px] h-auto object-contain shrink-0" />
            <div class="flex flex-col gap-3">
              <h3 class="text-xl font-semibold text-secondary dark:text-bg-primary">Compendium</h3>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed">
                The medical compendium app contains language based complete data set of medicinal products approved in Switzerland.
              </p>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed">
                The first full Kotlin App I made. Based on MVVM and Facade pattern it has an included Meta SQLite database. With Kotlin Coroutines this app optimizes its performance and the integrated bar code scan option gives the user easy product information access. Bookmarking you favourite products helps you to keep you products easy accessible.
              </p>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed">
                In cooperation with <a href="https://www.treeinspired.com/index.html" target="_blank" rel="noopener noreferrer" class="text-primary dark:text-highlight hover:underline">Treeinspired</a> this android app included many interesting challenges and technologies.
              </p>

              <!-- Store badges -->
              <div class="mt-2">
                <div class="flex flex-wrap gap-3 items-center">
                  <a href="https://play.google.com/store/apps/details?id=com.treeinspired.android.kompendium" target="_blank" rel="noopener noreferrer">
                    <img src="/img/google-play-badge.png" alt="Get it on Google Play" class="h-12 w-auto" />
                  </a>
                  <a href="https://apps.apple.com/us/app/compendium-medication-guide/id373040910" target="_blank" rel="noopener noreferrer">
                    <img src="/img/apple_store.png" alt="Download on the App Store" class="h-12 w-auto" />
                  </a>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-4 flex gap-2 flex-wrap">
            <a href="https://www.android.com" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Android</a>
            <a href="https://kotlinlang.org" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Kotlin</a>
          </div>
        </div>

        <!-- Project Card: Gambly -->
        <div class="bg-bg-secondary dark:bg-primary/10 rounded-design p-6 border border-bg-secondary dark:border-primary/20 hover:shadow-lg transition-shadow">
          <div class="flex flex-col sm:flex-row items-start gap-6">
            <img src="/img/gambly.png" alt="Gambly App" class="w-[240px] h-auto object-contain shrink-0" />
            <div class="flex flex-col gap-3">
              <h3 class="text-xl font-semibold text-secondary dark:text-bg-primary">Gambly</h3>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed">
                Gambly is the oldest maintained app in my store and was created to keep track of our board and card game scores. First it just had a score board, where you could add or generate players with name and color. After I regularly played Magic the Gathering with my friends, a new score board was added. The one on one score board is especially useful in these kind of games.
              </p>
              <p class="text-secondary/75 dark:text-bg-primary/75 text-base leading-relaxed">
                The app is quite simple but had some interesting new features to be implemented. Without ads flickering while playing, this app was reliable and comfortable to use.
              </p>

              <!-- Store badges -->
              <div class="mt-2">
                <div class="flex flex-wrap gap-3 items-center">
                  <a href="https://play.google.com/store/apps/details?id=lu.domi.sapphire.gambly" target="_blank" rel="noopener noreferrer">
                    <img src="/img/google-play-badge.png" alt="Get it on Google Play" class="h-12 w-auto" />
                  </a>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-4 flex gap-2 flex-wrap">
            <a href="https://www.android.com" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Android</a>
            <a href="https://www.java.com" target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1 rounded-full bg-primary/10 dark:bg-primary/20 text-primary dark:text-highlight font-medium hover:bg-primary/20 dark:hover:bg-primary/40 transition-colors">Java</a>
          </div>
        </div>

      </div>
    </section>

    <!-- About Me Section -->
    <section id="about" class="scroll-mt-20 mb-20">
      <h2 class="text-3xl font-bold text-secondary dark:text-bg-primary mb-8">About Me</h2>
      <div class="bg-bg-secondary dark:bg-primary/10 rounded-design p-8 border border-bg-secondary dark:border-primary/20">
        <p class="text-secondary/80 dark:text-bg-primary/80 leading-relaxed mb-4">
          While trimming the sails on the sea or taking your next steps in climbing a wall, motivation and interest are driving factors to succeed in your journey to your goals. This is why it is important to have the right tools and people you can trust.
        </p>
        <p class="text-secondary/80 dark:text-bg-primary/80 leading-relaxed mb-4">
          For me, software development is an always changing force of nature, ready to be conquered but always adapting. This is why the drive to learn new ways of completing tasks while also using the experience to improve and optimize workflow steps is important to me.
        </p>
        <p class="text-secondary/80 dark:text-bg-primary/80 leading-relaxed mb-4">
          My main proficiency is Java and Kotlin in mobile and backend. I am experienced in multiplatform projects (Android/iOS), integrating or creating new micro services or connecting different technologies in an adaptive, maintainable and secure way.
        </p>
        <p class="text-secondary/80 dark:text-bg-primary/80 leading-relaxed">
          My current personal focus is on Claude Code. By using it correctly it can be a valuable addition to my experience and skills.
        </p>
      </div>
    </section>

  </main>

  <style is:global>
    .tab-link {
      color: rgb(0 31 78 / 0.5);
      border-color: transparent;
    }
    .tab-link.active {
      color: #001F4E;
      border-color: #001F4E;
    }
    .dark .tab-link {
      color: rgb(255 255 255 / 0.6);
    }
    .dark .tab-link.active {
      color: #FFFFFF;
      border-color: #FFFFFF;
    }
  </style>

  <script>
    const sections = document.querySelectorAll<HTMLElement>('section[id]');
    const tabLinks = document.querySelectorAll<HTMLAnchorElement>('.tab-link');

    function setActive(id: string) {
      tabLinks.forEach((link) => {
        link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
      });
    }

    function getActiveSection(): string {
      const navHeight = (document.getElementById('tab-nav')?.offsetHeight ?? 56);
      let activeId = sections[0]?.id ?? '';
      for (const section of sections) {
        if (section.getBoundingClientRect().top <= navHeight + 8) {
          activeId = section.id;
        }
      }
      return activeId;
    }

    window.addEventListener('scroll', () => setActive(getActiveSection()), { passive: true });
    setActive(getActiveSection());
  </script>

</BaseLayout>
